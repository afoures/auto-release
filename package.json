{
  "name": "@afoures/auto-release",
  "version": "0.2.10",
  "description": "A file based release management tool for monorepos",
  "homepage": "https://github.com/afoures/auto-release#readme",
  "bugs": {
    "url": "https://github.com/afoures/auto-release/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afoures/auto-release.git"
  },
  "author": "Antoine Fourès <contact@afoures.com>",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components.d.mts",
      "import": "./dist/components.mjs"
    },
    "./package.json": "./package.json",
    "./platforms": {
      "types": "./dist/git-platforms.d.mts",
      "import": "./dist/git-platforms.mjs"
    },
    "./versioning": {
      "types": "./dist/versioning.d.mts",
      "import": "./dist/versioning.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "auto-release": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.9",
    "arkregex": "^0.0.5",
    "human-id": "^4.1.3",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.10.4",
    "bumpp": "^10.3.2",
    "oxfmt": "^0.20.0",
    "oxlint": "^1.35.0",
    "tsdown": "^0.18.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@8.15.9+sha512.499434c9d8fdd1a2794ebf4552b3b25c0a633abcee5bb15e7b5de90f32f47b513aca98cd5cfd001c31f0db454bc3804edccd578501e4ca293a6816166bbd9f81",
  "engines": {
    "node": ">=22.0.0"
  }
}
